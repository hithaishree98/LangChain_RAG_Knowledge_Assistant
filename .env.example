# LLM provider key. The app currently uses Gemini (gemini-2.5-flash).
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI embeddings key (recommended for production deploys).
# When set, get_embedder() uses text-embedding-3-small over the network —
# ~50-200ms per chunk regardless of host CPU/GPU, ~$0.02 per 1M tokens.
# When unset, falls back to a local sentence-transformers/all-MiniLM-L6-v2
# model (free, slower, downloads ~80MB on first use).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Kept for backward compatibility; no longer used by the app.
GROQ_API_KEY=your_groq_api_key_here

# Strong random string used to authenticate API requests (X-API-Key header).
# In production: generate with `python -c "import secrets; print(secrets.token_hex(32))"`.
# When empty: all protected endpoints are open — dev mode only, never leave unset in production.
API_KEY=

# Persistent secret used to sign JWT workspace tokens.
# In production: must be set and kept stable across restarts — tokens are invalidated on every
# restart if this is not set, silently logging users out after each deploy.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# "production" enforces that API_KEY and JWT_SECRET are set; anything else is dev mode.
ENVIRONMENT=development

API_BASE_URL=http://localhost:8000

# Comma-separated list of origins allowed to call the API (CORS).
# In production: set this to your frontend domain, e.g. https://your-app.example.com.
# In development: http://localhost:8501 (Streamlit default).
ALLOWED_ORIGINS=http://localhost:8501

SLACK_WEBHOOK_URL=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=optional
LANGCHAIN_PROJECT=rag-assistant

# ── Experiment flags ──────────────────────────────────────────────────────────
# These are set automatically by the Python experiment scripts (exp1–exp6).
# You do NOT need to set them here for normal use or production.
# All defaults below are the production behavior.
#
# Disable the LLM hallucination judge to save LLM tokens during ablation runs.
# Set to 0 in your shell before running an experiment: ENABLE_LLM_JUDGE=0 python ...
# ENABLE_LLM_JUDGE=1
#
# CHUNKING_MODE=full         # baseline | sentence | full (exp1)
# RETRIEVAL_MODE=full        # dense | dense_bm25 | full (exp2)
# WORKFLOW_MODE=loop         # single_pass | loop (exp3)
# NODE_TIMING=               # set to 1 to log per-node latency (exp5)
# TOKEN_LOGGING=             # set to 1 to log real LLM token counts (exp6)
#
# Contextual retrieval (Anthropic, Sep 2024). When enabled, each chunk is
# situated within its document by an LLM before embedding — recovers cross-
# chunk references ("the fix", "this customer") that naive chunking drops.
# Reported +35-49% retrieval accuracy at the cost of one LLM call per chunk
# at ingest time (one-time cost — retrieval-time latency is unchanged).
# CONTEXTUAL_RETRIEVAL=1
